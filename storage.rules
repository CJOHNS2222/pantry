rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /recipes/{recipeId} {
      // Allow public read access to recipe images (anyone can view)
      allow read: if true;
      // Allow write access to authenticated users for recipe images
      allow write: if request.auth != null &&
                   request.resource.size < 10 * 1024 * 1024 && // 10MB limit
                   request.resource.contentType.matches('image/.*');
    }

    // Recipe photos uploaded by users (for ratings and results)
    match /recipe-photos/{allPaths=**} {
      // Allow public read access to recipe photos
      allow read: if true;
      // Allow write access to authenticated users for recipe photos
      allow write: if request.auth != null &&
                   request.resource.size < 10 * 1024 * 1024 && // 10MB limit
                   request.resource.contentType.matches('image/.*');
      // Allow delete access to authenticated users for their own uploads
      allow delete: if request.auth != null;
    }

    // Allow read/write access to user-specific content
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Pantry item images for caching (uploaded by imageCacheService)
    match /pantry_images/{allPaths=**} {
      // Allow public read access to pantry images (for efficient caching)
      allow read: if true;
      // Allow write access to authenticated users for pantry images
      allow write: if request.auth != null &&
                   request.resource.size < 5 * 1024 * 1024 && // 5MB limit (smaller for pantry items)
                   request.resource.contentType.matches('image/.*');
      // Allow delete access to authenticated users
      allow delete: if request.auth != null;
    }
  }
}
