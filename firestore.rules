rules_version = '2';
/**
 * Firestore Security Rules for Smart Pantry Chef
 *
 * Security improvements implemented:
 * - Admin-only access for system and app version collections
 * - Data validation for user-generated content (recipes, ratings, prices)
 * - User ownership validation for updates/deletes
 * - Reasonable data limits to prevent abuse
 */
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if user is admin (admins collection)
    function isAdmin() {
      return request.auth != null
        && get(/databases/$(database)/documents/admins/$(request.auth.uid)).exists();
    }

    // A user can create their own user document and read/write to all of their own data (documents and subcollections)
    match /users/{userId}/{documents=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Households top-level doc - create allowed if creator included in memberIds
    match /households/{householdId} {
      allow create: if request.auth != null
        && request.resource.data.memberIds is list
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.memberIds;

      // Allow only household members to read household data
      allow read: if request.auth != null && request.auth.uid in resource.data.memberIds;
      allow update: if request.auth != null && request.auth.uid in resource.data.memberIds;
      allow delete: if request.auth != null && request.auth.uid in resource.data.memberIds;
    }

    // Household subcollections: check membership in household document
    match /households/{householdId}/{subCollection=**} {
      allow read, write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // Note: product_master collection removed; denormalized item fields used instead.

    // Household cache documents - explicit rule for cache
    match /households/{householdId}/cache/{cacheDoc} {
      allow read, write: if request.auth != null
        && request.auth.uid in get(/databases/$(database)/documents/households/$(householdId)).data.memberIds;
    }

    // Per-user saved recipes cache: single document storing an array of saved recipes
    match /users/{userId}/cache/savedRecipes {
      allow read, write: if request.auth != null && request.auth.uid == userId
        && (
          // Basic validation on write: recipes array and lastUpdated present
          request.resource.data.keys().hasAny(['recipes', 'lastUpdated'])
        );
    }

    // Public ratings collection (Community) - restrict to authenticated users with validation
    match /ratings/{docId} {
      allow read: if request.auth != null; // Require authentication for reading ratings
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['recipeId', 'rating', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5; // Valid rating range
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Recipe ratings collection - allow authenticated users to read/write their own ratings
    match /recipeRatings/{docId} {
      allow read: if request.auth != null; // Require authentication for reading ratings
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['recipeTitle', 'rating', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.rating is number
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5; // Valid rating range
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Feedback collection: allow authenticated users to create feedback but with limits
    match /feedback/{docId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['message'])
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000
        && ( !('userId' in request.resource.data) || request.resource.data.userId == request.auth.uid );
      allow read: if false; // Only allow creation, no reading for privacy
      allow update, delete: if isAdmin();
    }

    // Notifications collection: users can only access their own notifications
    match /notifications/{notificationId} {
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // App versions collection: allow read for all authenticated users, write only for admins
    match /app_versions/{platform} {
      allow read: if request.auth != null; // Require authentication for version checks
      allow write: if isAdmin(); // Only admins can update version info
    }

    // Grocery prices collection: allow authenticated users to contribute but validate data
    match /groceryPrices/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['itemName', 'price', 'store', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.price < 1000; // Reasonable price limit
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Price history collection: allow authenticated users to contribute historical data
    match /priceHistory/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['itemName', 'price', 'store', 'date', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.price is number
        && request.resource.data.price > 0
        && request.resource.data.price < 1000;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Global recipes collection: allow public recipes and private user-owned recipes.
    // Clients may save recipes as private (visibility: 'private') so only the owner can read them.
    match /recipes/{recipeId} {
      // Read rules:
      // - Public recipes are readable by any authenticated user
      // - Private recipes are readable only by their owner
      allow get, list: if request.auth != null && (
        // If resource exists, allow read when public
        (resource.data.visibility == 'public') ||
        // Or allow read for owner (private or otherwise)
        (resource.data.userId == request.auth.uid)
      );

      // Create: authenticated users may create recipes and must set `userId` to their UID.
      // If `visibility` is present it must be either 'public' or 'private'.
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'userId'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() < 200
        && (
          !('visibility' in request.resource.data) ||
          (request.resource.data.visibility in ['public', 'private'])
        );

      // Update/Delete: only the owner can modify or delete their recipe. Owners can change visibility.
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid
        && (
          // On update, if visibility is being set ensure it's valid
          !(('visibility' in request.resource.data) && !(request.resource.data.visibility in ['public', 'private']))
        );
    }

    // Recipe submissions (recipes submitted for staff review) are stored under `recipes/submissions/{submissionId}`
    // - Any authenticated user may create a submission for their recipe; `submitterId` must match auth uid and `status` must be 'pending'
    // - Submitter and admins may read the submission; only admins may update status fields
    match /recipes/submissions/{submissionId} {
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['title', 'userId', 'submitterId', 'status'])
        && request.resource.data.submitterId == request.auth.uid
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.title is string
        && request.resource.data.title.size() > 0
        && request.resource.data.title.size() < 200
        && request.resource.data.status == 'pending';

      allow read: if request.auth != null && (
        resource.data.submitterId == request.auth.uid || isAdmin()
      );

      // Only admins may change the submission status (approve/reject). Allow admins to update.
      allow update: if request.auth != null && isAdmin();
      allow delete: if request.auth != null && (isAdmin() || resource.data.submitterId == request.auth.uid);
    }

    // Recipe search index: read-only for authenticated users, admin write access
    match /recipe_search_index/{recipeId} {
      allow read: if request.auth != null; // Allow authenticated users to search
      allow write: if isAdmin(); // Only admins can update the search index
    }

    // Recipe modifications collection: allow authenticated users to suggest modifications
    match /recipeModifications/{docId} {
      allow read: if request.auth != null; // Allow authenticated users to read modifications
      allow create: if request.auth != null
        && request.resource.data.keys().hasAll(['recipeTitle', 'userId', 'description'])
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.description is string
        && request.resource.data.description.size() > 0
        && request.resource.data.description.size() < 500; // Reasonable description length
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Recipe community stats: clients should NOT be allowed to arbitrarily update aggregated stats.
    // Only admin processes (or server-side scripts using the Admin SDK) should write these documents.
    match /recipeCommunityStats/{docId} {
      allow read: if request.auth != null;
      allow create, update: if isAdmin();
    }

    // Image cache collection: limited client writes. Clients may create a small cache entry
    // but fields are validated. Server/admin processes may manage larger cache operations.
    match /image_cache/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.resource.data.keys().hasAny(['itemId', 'url', 'uploader'])
        && request.resource.data.itemId is string
        && request.resource.data.url is string
        && request.resource.data.uploader == request.auth.uid
        && request.resource.data.url.size() < 2000;
      allow update, delete: if isAdmin();
    }

    // Price data cache: allow authenticated users to read/write the single global cache document.
    match /price_cache/priceData {
      allow read, write: if request.auth != null;
    }

    // System collection: allow read access for authenticated users (for cached data like popular recipes)
    // Allow authenticated users to read any system doc, but allow client writes only to the
    // single-document community cache `system/community_rated_recipes` with basic validation.
    match /system/community_rated_recipes {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        // expect a recipes array and lastUpdated
        && request.resource.data.keys().hasAny(['recipes', 'lastUpdated'])
        && request.resource.data.recipes is list
        // keep document size reasonable
        && request.resource.data.recipes.size() <= 500;
    }

    // Other system documents remain admin-only for writes
    match /system/{docId} {
      allow read: if request.auth != null; // Authenticated users can read system data
      allow write: if isAdmin(); // Only admins can write other system data
    }

    // Recipe cache documents: allow authenticated users to read cache documents
    // (These documents are generated by admin scripts and should be readable by
    // authenticated clients to avoid fan-out reads across many recipe docs.)
    match /recipe_caches/{cacheDoc} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
