{
  "name": "stockandspoon",
  "private": true,
  "version": "2.4.2",
  "type": "module",
  "scripts": {
    "generate:changelog": "node scripts/generate-changelog.cjs",
    "predev": "node scripts/generate-changelog.cjs",
    "prebuild": "node scripts/generate-changelog.cjs",
    "dev": "vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "build:release": "npm run sync-release-notes && npm run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "e2e:playwright": "playwright test",
    "test:ui": "vitest --ui",
    "generate:icons": "npx pwa-asset-generator public/icons/icon512.png resources --manifest ./public/manifest.webmanifest --favicon --index --android --ios",
    "sync-release-notes": "node scripts/sync-release-notes.js",
    "bulk-upload-recipes": "node scripts/bulk-upload-recipes.js",
    "bulk-delete-incomplete-recipes": "node scripts/bulk-delete-incomplete-recipes.js",
    "postinstall": "patch-package",
    "clean-duplicate-descriptions": "node scripts/clean-duplicate-descriptions.js",
    "test-spoonacular": "node scripts/test-spoonacular.js",
    "seed:images": "node scripts/seed-ingredient-images.cjs",
    "seed:images:resume": "node scripts/seed-ingredient-images.cjs --resume",
    "seed:images:cdn-only": "node scripts/seed-ingredient-images.cjs --cdn-only",
    "seed:images:cleanup": "node scripts/cleanup-placeholder-images.cjs",
    "images:remove-white-bg": "node scripts/remove-white-backgrounds.cjs",
    "images:remove-white-bg:cleanup": "node scripts/remove-white-backgrounds.cjs --cleanup-temps-only --no-update-refs",
    "seed:images:fallback": "node scripts/seed-ingredient-images-fallback.cjs",
    "seed:images:fallback:resume": "node scripts/seed-ingredient-images-fallback.cjs --resume",
    "rebuild-community-cache": "node scripts/rebuild-community-cache.js",
    "migrate-firebase": "node scripts/migrate-firebase.js",
    "test-firebase": "node scripts/test-firebase.js",
    "version:publish": "node scripts/publish-version.cjs",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=999"
    ]
  },
  "dependencies": {
    "@capacitor-community/admob": "^8.0.0",
    "@capacitor-community/speech-recognition": "^7.0.1",
    "@capacitor-firebase/crashlytics": "^8.2.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/browser": "^8.0.3",
    "@capacitor/camera": "^8.2.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/device": "^8.0.2",
    "@capacitor/filesystem": "~8.1.2",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/local-notifications": "^8.2.0",
    "@capacitor/network": "~8.0.1",
    "@capacitor/push-notifications": "^8.0.3",
    "@capacitor/share": "~8.0.1",
    "@capawesome/capacitor-app-review": "^8.0.1",
    "@codetrix-studio/capacitor-google-auth": "^3.4.0-rc.4",
    "@google/genai": "^2.6.0",
    "@opentelemetry/api": "^1.9.1",
    "@sentry/react": "^10.51.0",
    "@zxing/library": "^0.23.0",
    "adb": "^0.2.0",
    "capacitor-plugin-safe-area": "^5.0.0",
    "cordova-plugin-purchase": "^13.15.4",
    "date-fns": "^4.1.0",
    "firebase": "^12.12.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-intl": "^10.1.9",
    "react-router-dom": "^7.15.0",
    "react-swipeable": "^7.0.2",
    "react-window": "^1.8.11",
    "tesseract.js": "^7.0.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/nodemailer": "^8.0.0",
    "@types/react-dom": "^19.2.3",
    "@types/react-window": "^1.8.8",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "firebase-admin": "^13.8.0",
    "firebase-functions": "^7.2.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "jiti": "^2.7.0",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.5",
    "msw": "^2.14.3",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.14",
    "postinstall-postinstall": "^2.1.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.10",
    "vite-plugin-checker": "^0.13.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.1.5"
  }
}
