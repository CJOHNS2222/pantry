{
  "name": "smartpantry",
  "private": false,
  "version": "1.1.8",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:release": "npm run sync-release-notes && npm run build",
    "preview": "vite preview",
    "test": "vitest",
    "type-check": "tsc --noEmit",
    "e2e:playwright": "playwright test",
    "test:ui": "vitest --ui",
    "generate:icons": "npx pwa-asset-generator public/icons/icon512.png resources --manifest ./public/manifest.webmanifest --favicon --index --android --ios",
    "sync-release-notes": "node scripts/sync-release-notes.js",
    "bulk-upload-recipes": "node scripts/bulk-upload-recipes.js",
    "bulk-delete-incomplete-recipes": "node scripts/bulk-delete-incomplete-recipes.js",
    "clean-duplicate-descriptions": "node scripts/clean-duplicate-descriptions.js",
    "test-spoonacular": "node scripts/test-spoonacular.js",
    "migrate-firebase": "node migrate-firebase.js",
    "test-firebase": "node test-firebase.js"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.2",
    "@capacitor/app": "^7.0.0",
    "@capacitor/browser": "^7.0.0",
    "@capacitor/camera": "^7.0.0",
    "@capacitor/cli": "^6.1.2",
    "@capacitor/core": "^6.1.2",
    "@capacitor/device": "^7.0.0",
    "@capacitor/local-notifications": "^7.0.0",
    "@google/genai": "^1.31.0",
    "@paypal/react-paypal-js": "^8.9.2",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.5.3",
    "@zxing/library": "^0.21.3",
    "adb": "^0.2.0",
    "firebase": "^12.6.0",
    "firebase-admin": "^13.6.0",
    "lucide-react": "^0.555.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-window": "^1.8.8"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.0.0",
    "eslint-plugin-import": "^2.32.0",
    "jsdom": "^27.3.0",
    "typescript": "~5.8.2",
    "vite": "^6.4.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.15"
  }
}
