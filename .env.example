# Gemini AI
VITE_GEMINI_API_KEY=your_gemini_api_key

# Spoonacular API (Free tier: 150 requests/day)
VITE_SPOONACULAR_API_KEY=your_spoonacular_api_key

# Google Custom Search Engine
VITE_GOOGLE_CSE_API_KEY=your_cse_api_key
VITE_GOOGLE_CSE_ID=your_cse_id

# Firebase Configuration
VITE_API_KEY=your_firebase_api_key
VITE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_PROJECT_ID=your_project_id
VITE_STORAGE_BUCKET=your_project.appspot.com
VITE_MESSAGING_SENDER_ID=your_sender_id
VITE_APP_ID=your_app_id
VITE_MEASUREMENT_ID=your_measurement_id

# Stripe (Public key only - secret key goes to Firebase Functions)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_publishable_key

# EmailJS (Optional)
VITE_EMAILJS_SERVICE_ID=your_service_id
VITE_EMAILJS_TEMPLATE_ID=your_template_id
VITE_EMAILJS_PUBLIC_KEY=your_public_key

# Firebase Functions
VITE_FIREBASE_FUNCTIONS_URL=https://your-region-your-project.cloudfunctions.net
